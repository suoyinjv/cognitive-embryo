# 认知胚胎 — 环境配置
#
# 使用前复制此文件为 .env 并填入真实值
# cp .env.example .env

# 大模型 API Key（必填，DeepSeek 推荐）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# API 地址（DeepSeek 默认）
CE_BASE_URL=https://api.deepseek.com

# 模型名（DeepSeek 默认 deepseek-chat）
CE_MODEL=deepseek-chat

# ── 以下可选配置 ──

# 运行最大迭代次数
# CE_MAX_ITERATIONS=200

# 单任务最大重试次数
# CE_MAX_RETRIES=5

# 目标审视触发间隔（每N次迭代）
# CE_INTROSPECTION_INTERVAL=15

# 沙箱类型 (subprocess | docker)
# CE_SANDBOX_TYPE=subprocess

# 是否启用安全外壳
# CE_SAFETY_ENABLED=false

# 是否自动修正目标（需谨慎）
# CE_AUTO_REVISE_GOALS=false
